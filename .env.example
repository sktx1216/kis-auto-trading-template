# KIS API credentials
# Use mock trading credentials first. Keep DRY_RUN=true until you fully understand the strategy.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_CANO=
KIS_ACNT_PRDT_CD=01
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# Safety
DRY_RUN=true
MARKET_HOURS_GUARD=true

# Portfolio data repository
# Option A, local:
PORTFOLIO_DATA_DIR=./portfolio-data

# Option B, GitHub Actions:
# PORTFOLIO_DATA_REPO_URL=https://x-access-token:YOUR_GITHUB_TOKEN@github.com/YOUR_GITHUB_ID/kis-portfolio-data.git

# Account sizing
MAX_POSITIONS=10
TARGET_POSITION_RATIO=0.095
MAX_POSITION_RATIO=0.12
CASH_BUFFER_RATIO=0.05
SMALL_ACCOUNT_THRESHOLD_USD=2000
SMALL_ACCOUNT_MAX_POSITIONS=3
SMALL_ACCOUNT_TARGET_POSITION_RATIO=0.30
SMALL_ACCOUNT_MAX_POSITION_RATIO=0.45
SMALL_ACCOUNT_MAX_FIRST_SHARE_CASH_RATIO=0.90

# Buy limits
MAX_BUY_PER_DAY_STRONG=2
MAX_BUY_PER_DAY_NORMAL=1
MAX_BUY_PER_DAY_WEAK=0
ALLOW_WEAK_MARKET_RELATIVE_STRENGTH_BUY=true
MAX_BUY_PER_DAY_WEAK_RELATIVE_STRENGTH=1
MIN_WEAK_MARKET_RELATIVE_STRENGTH_SCORE=85

# Scanner risk filters
MIN_BUY_TODAY_RETURN_PERCENT=-1
MAX_BUY_TODAY_RETURN_PERCENT=4
MAX_BUY_GAP_PERCENT=4
MAX_BUY_GAP_DOWN_PERCENT=2.5
MAX_BUY_INTRADAY_RANGE_PERCENT=6
MIN_BUY_PREVIOUS_DAY_RETURN_PERCENT=-3.0
MIN_BUY_RECENT_3D_RETURN_PERCENT=-4.0
MAX_BUY_VOLUME_SPIKE_RATIO=2.5
MIN_AVG_TRADE_VALUE_20=1000000000

# Optional manual controls
MANUAL_BLOCK_LIST=
CYCLICAL_TRAVEL_RISK_MODE=true
CYCLICAL_TRAVEL_RISK_SYMBOLS=BKNG,ABNB,MAR
CYCLICAL_TRAVEL_RISK_PENALTY=10
